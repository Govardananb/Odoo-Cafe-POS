# =============================================================================
# Odoo Cafe POS — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# --- App URL -------------------------------------------------------------------
# When running locally only (no mobile access):
NEXT_PUBLIC_APP_URL=http://localhost:3000

# When exposing via ngrok for mobile QR testing:
# NEXT_PUBLIC_APP_URL=https://abc123.ngrok-free.app
#
# Steps to get the ngrok URL:
#   1. Run: ngrok http 3000
#   2. Copy the "Forwarding" URL (e.g. https://abc123.ngrok-free.app)
#   3. Set NEXT_PUBLIC_APP_URL to that URL
#   4. Restart Next.js (Ctrl+C then npm run dev)
# ------------------------------------------------------------------------------

# --- Optional: ngrok auth token (if using ngrok account for longer sessions) ---
# NGROK_AUTHTOKEN=your_token_here
